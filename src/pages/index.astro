<style>
  :global(html) { 
    scroll-behavior: smooth; 
    font-family: 'Inter', sans-serif; 
    background: #0c0c0c; 
    color: #fff; 
    margin: 0; 
  }

  .app-container { 
    display: flex; 
    width: 100%;
  }

  .sidebar {
    width: 280px;
    height: 100vh;
    background: #151515;
    position: fixed; /* Stays locked on the left */
    border-right: 4px solid #ff7b00; 
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    z-index: 100; /* Stays on top */
  }

  .content-area { 
    margin-left: 280px; /* The width of your sidebar */
    width: calc(100% - 280px); 
    display: flex;
    flex-direction: column;
    /* This is the magic change: align to the start (left) */
    align-items: flex-start; 
    /* This creates the consistent gap from the orange bar */
    padding-left: 100px; 
    padding-right: 5vw;
    padding-top: 0;
  }

  .milestone-section { 
    min-height: 100vh; 
    width: 100%;
    max-width: 800px; 
    display: flex; 
    flex-direction: column; 
    justify-content: center; 
    border-bottom: 1px solid #1a1a1a;
  }

  .content-box {
    width: 100%;
    text-align: left; 
  }

  /* Adjusting for 4K */
  h1 { 
    font-size: clamp(3.5rem, 6vw, 5.5rem); 
    margin: 0; 
    line-height: 0.85; 
    color: #fff;
    text-align: left;
  }

  /* BRANDING & TEXT */
  .brand-h { color: #ff7b00; margin: 0; font-size: 1.8rem; font-weight: 900; letter-spacing: -1px; }
  .brand-c { color: #00a2ff; font-size: 0.9rem; font-weight: 700; letter-spacing: 2px; }
  .step { color: #ff7b00; font-weight: 800; font-size: 1.1rem; text-transform: uppercase; }
  h1 { font-size: clamp(3rem, 8vw, 5rem); margin: 0; line-height: 0.9; }
  h2 { font-size: clamp(2rem, 5vw, 3.5rem); color: #00a2ff; margin: 0.5rem 0; }
  .subtitle { font-size: 1.8rem; color: #ff7b00; margin-top: 1rem; }
  .summary { color: #aaa; line-height: 1.7; font-size: 1.2rem; margin-top: 2rem; }

  /* BUTTONS & BADGES */
  .btn { display: inline-block; margin-top: 2rem; padding: 0.9rem 1.8rem; background: #00a2ff; color: white; text-decoration: none; border-radius: 4px; font-weight: 700; transition: 0.2s; width: fit-content; }
  .btn.secondary { background: transparent; border: 2px solid #ff7b00; color: #ff7b00; margin-right: 1rem; }
  .status-badge { margin-top: 2rem; background: #ff7b00; color: #fff; padding: 0.5rem 1rem; border-radius: 4px; font-weight: bold; width: fit-content; }
specs-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
  }
  .specs-list li {
    margin-bottom: 0.8rem;
    padding-left: 1.5rem;
    position: relative;
    color: #ccc;
    font-size: 1rem;
    line-height: 1.5;
  }
  .specs-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: #ff7b00; 
    font-weight: bold;
  }
  .btn-group {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .dashboard-preview img {
  width: 100%;
  height: 450px; /* Forces height */
  overflow: hidden; /* Hides what doesn't fit */
  border-radius: 12px;
  border: 1px solid #333;
  margin: 20px 0;
  background: #fff; /* Ensures the dashboard background stays clean */
}
.dashboard-window {
  width: 100%;
  max-width: 900px; /* Limits the width  */
  margin: 25px auto;
  background: #fff; /* White background */
  border-radius: 12px;
  border: 1px solid #444;
  overflow: hidden;
  box-shadow: 0 10px 40px rgba(0,0,0,0.6);
}

.dashboard-window img {
  width: 100%;
  height: 350px; /* Forced height to keep text on screen */
  object-fit: contain; /* Shows as much as possible without stretching */
  padding: 15px;
  display: block;
}
.phase-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

/* The Professional Button */
.btn-download {
  background: #007bff;
  color: white !important;
  text-decoration: none;
  padding: 10px 20px;
  border-radius: 6px;
  font-weight: bold;
  font-size: 0.9rem;
  transition: background 0.2s ease;
}

.btn-download:hover {
  background: #0056b3;
}

/* The Tech Pills */
.pill-container {
  display: flex;
  gap: 12px;
  margin-top: 15px;
}

.tech-tag {
  background: rgba(0, 255, 204, 0.1);
  border: 1px solid #00ffcc;
  color: #00ffcc;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
}
.invoice-window {
  width: 100%;
  height: 500px;
  overflow-y: auto;
  border: 1px solid #444;
